# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/world_cup_2026?schema=public"

# Better Auth Configuration
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Maximum number of bets a user can create (default: 3)
# MAX_BETS_PER_USER=3

# Set bet signature prefix
# BET_SIGNATURE_SALT=wc2026

# Live feed token — required in production; absent = API is disabled (503)
# Generate a strong random secret (e.g.: openssl rand -hex 32)
# LIVE_FEED_TOKEN=

# Client-side refresh interval in milliseconds for calendar and standings (default: 1 minute)
NEXT_PUBLIC_REFRESH_INTERVAL=60000

# Cron pattern for in-process live feed poller ticks (default: */2 * * * * = every 2 minutes)
LIVE_TICK_CRON="*/2 * * * *"

# Live Feed configuration
# Sourced from 'mock' (default) or 'worldcup26'
LIVE_FEED_SOURCE=mock
LIVE_FEED_BASE_URL=https://worldcup26.ir
