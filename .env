# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/world_cup_2026?schema=public"

# Better Auth Configuration
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Maximum number of bets a user can create (default: 3)
# MAX_BETS_PER_USER=3

# Set bet signature prefix
# BET_SIGNATURE_SALT=wc2026
