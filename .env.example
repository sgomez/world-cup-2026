# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/world_cup_2026?schema=public"

# ---------------------------------------------------------------------------
# Auth (Better Auth + Google OAuth)
# https://console.cloud.google.com/
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Bet settings
# ---------------------------------------------------------------------------

# Maximum number of bets a user can create (default: 3)
# MAX_BETS_PER_USER=3

# Set bet signature prefix
# BET_SIGNATURE_SALT=wc2026

# Deadline for placing bets (ISO UTC datetime)
# BET_DEADLINE="2026-06-11T19:00:00Z"

# ---------------------------------------------------------------------------
# Live Feed
# ---------------------------------------------------------------------------

# Live feed HTTP API token — required in production; absent = API is disabled (503)
# Generate a strong random secret (e.g.: openssl rand -hex 32)
# LIVE_FEED_TOKEN=

# Which live feed source to use:
#   mock   — echoes stored scoreline, derives phase/minute from elapsed time (default, safe for dev/test)
#   openai — LLM-backed adapter using OpenAI web search to fetch real match state (requires OPENAI_API_KEY)
# LIVE_FEED_SOURCE=mock

# OpenAI API key — required when LIVE_FEED_SOURCE=openai.
# If missing or empty and source=openai, the app falls back to MockLiveFeed (fail-safe).
# OPENAI_API_KEY=

# OpenAI model to use for the live feed (must support web_search tool).
# Confirmed web-search-capable models: gpt-5.5, gpt-5.4, gpt-4.1, gpt-4.1-mini, gpt-5.4-mini.
# Note: gpt-5-nano web-search support is undocumented — do not use it.
# Default: gpt-5.4-mini
# LIVE_FEED_MODEL=gpt-5.4-mini

# ---------------------------------------------------------------------------
# Poller / Scheduler
# ---------------------------------------------------------------------------

# Cron pattern for in-process live feed poller ticks (default: every 5 minutes).
# LIVE_TICK_CRON="*/5 * * * *"

# ---------------------------------------------------------------------------
# Client-side refresh
# ---------------------------------------------------------------------------

# Refresh interval in milliseconds for calendar and standings (default: 1 minute)
NEXT_PUBLIC_REFRESH_INTERVAL=60000
